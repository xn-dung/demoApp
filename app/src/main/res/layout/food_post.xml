<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".UI.FoodPostActivity">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="@drawable/white_rectangle_background"
        android:contentDescription="Back"
        android:elevation="3dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:dividerPadding="8dp">

            <TextView
                android:id="@+id/labelTenMon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên món:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/tvTenMon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/labelNguyenLieu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyên liệu:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingTop="12dp" />

            <TextView
                android:id="@+id/tvNguyenLieu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/labelCachLam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cách làm:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingTop="12dp" />

            <TextView
                android:id="@+id/tvCachLam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/labelLuotThich"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lượt thích:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingTop="12dp" />

            <TextView
                android:id="@+id/tvLuotThich"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/labelVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video hướng dẫn:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingTop="12dp" />

            <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                android:id="@+id/youtubePlayerView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
